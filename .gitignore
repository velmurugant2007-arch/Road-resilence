# ============================================================================
# Project ATLAS — Route Resilience
# .gitignore
# ============================================================================

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
venv/
env/
.env/
.venv/
ENV/

# ---- Node.js ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- ML / AI Artifacts ----
*.h5
*.hdf5
*.ckpt
*.ckpt.*
*.pth
*.pt
*.onnx
*.tflite
*.pb
*.savedmodel/
wandb/
mlruns/
lightning_logs/
*.tfevents.*

# ---- Datasets (large files — use Git LFS or DVC) ----
datasets/raw/**/*.tif
datasets/raw/**/*.tiff
datasets/raw/**/*.img
datasets/raw/**/*.jp2
datasets/processed/**/*.npy
datasets/processed/**/*.npz
datasets/augmented/
*.tar.gz
*.zip

# ---- GIS ----
*.shx
*.dbf
*.prj
*.cpg
*.sbn
*.sbx
*.shp.xml

# ---- Models (large binary — use Git LFS) ----
models/**/*.pth
models/**/*.pt
models/**/*.onnx
models/**/*.h5

# ---- IDE / Editor ----
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ---- OS ----
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---- Logs ----
logs/*.log
*.log

# ---- Environment variables ----
.env
.env.local
.env.*.local

# ---- Jupyter ----
.ipynb_checkpoints/

# ---- Coverage / Testing ----
htmlcov/
.coverage
.coverage.*
.pytest_cache/
.tox/
nosetests.xml
coverage.xml

# ---- Build artifacts ----
*.exe
*.dll
*.lib
*.o
*.obj

# ---- Temporary files ----
tmp/
temp/
*.tmp
